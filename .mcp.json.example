{
  "comment": "Copy to .mcp.json (gitignored) and fill in a Notion internal-integration token (ntn_...). Provides the official Notion MCP server so sessions can read/write Notion (e.g. fetch the 员工管理 PRD) without browser OAuth.",
  "mcpServers": {
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\":\"Bearer ntn_REPLACE_WITH_YOUR_TOKEN\",\"Notion-Version\":\"2022-06-28\"}"
      }
    }
  }
}
