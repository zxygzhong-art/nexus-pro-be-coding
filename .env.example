APP_ENV=development
HTTP_ADDR=:18080
LOG_LEVEL=info

DATABASE_URL=postgres://nexuse-pro:nexus-pro-password@127.0.0.1:25432/nexus_pro?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=1
DB_MAX_CONN_LIFETIME=1h

REDIS_ADDR=127.0.0.1:26379
REDIS_PASSWORD=
REDIS_DB=0

# 以逗號分隔的精確 CORS 來源清單；空值會停用 CORS headers。
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3002,http://localhost:3002

# 以逗號分隔的 reverse proxy CIDR/IP；只有這些來源的 X-Forwarded-For
# 會用於解析 client IP（例如 10.0.0.0/8,192.168.1.1）。空值表示不信任任何 proxy。
TRUSTED_PROXIES=

# 獨立 Prometheus /metrics server 的 listen address；明確設為空字串可停用 metrics listener。
METRICS_ADDR=0.0.0.0:9091

# 每個 client IP 的 rate limiting；設定 REDIS_ADDR 時使用 Redis，否則使用 process 內 token bucket。
RATE_LIMIT_ENABLED=false
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

KEYCLOAK_ISSUER_URL=http://127.0.0.1:8080/realms/nexus-pro
KEYCLOAK_CLIENT_ID=nexus-pro-connect-api
KEYCLOAK_PROVISION_USERS=false
KEYCLOAK_ADMIN_CLIENT_ID=
KEYCLOAK_ADMIN_CLIENT_SECRET=
KEYCLOAK_SEND_INVITE_EMAIL=false
KEYCLOAK_INVITE_CLIENT_ID=nexus-pro-connect-api
KEYCLOAK_INVITE_REDIRECT_URL=

OPENFGA_API_URL=http://127.0.0.1:24081
OPENFGA_STORE_ID=
OPENFGA_MODEL_ID=
OPENFGA_SCOPE_CHECK_ENABLED=false

OBJECT_STORE_PROVIDER=minio
OBJECT_STORE_DIR=
OBJECT_STORE_ENDPOINT=http://127.0.0.1:24900
OBJECT_STORE_BUCKET=nexus-hr-imports
OBJECT_STORE_REGION=us-east-1
OBJECT_STORE_ACCESS_KEY_ID=minioadmin
OBJECT_STORE_SECRET_ACCESS_KEY=minioadmin
OBJECT_STORE_USE_SSL=false
OBJECT_STORE_CREATE_BUCKET=true

EHRMS_BASE_URL=
EHRMS_API_KEY=
EHRMS_SYNC_ENABLED=false
EHRMS_SYNC_INTERVAL=24h
EHRMS_SYNC_MODE=upsert
EHRMS_SYNC_TENANT_ID=
EHRMS_SYNC_ACCOUNT_ID=
EHRMS_SYNC_RUN_ON_START=false

OTEL_ENABLED=true
OTEL_SERVICE_NAME=nexus-pro-be
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:24317
OTEL_EXPORTER_OTLP_INSECURE=true
