APP_ENV=development
HTTP_ADDR=:18080
LOG_LEVEL=info

DB_HOST=127.0.0.1
DB_PORT=25432
DB_USERNAME=nexuse-pro
DB_PASSWORD=nexus-pro-password
DB_NAME=nexus_pro
DB_SSLMODE=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=1
DB_MAX_CONN_LIFETIME=1h

REDIS_HOST=127.0.0.1
REDIS_PORT=26379
REDIS_PASSWORD=
REDIS_DB=0

# 以逗號分隔的精確 CORS 來源清單；空值會停用 CORS headers。
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3002,http://localhost:3002

# 以逗號分隔的 reverse proxy CIDR/IP；只有這些來源的 X-Forwarded-For
# 會用於解析 client IP（例如 10.0.0.0/8,192.168.1.1）。空值表示不信任任何 proxy。
TRUSTED_PROXIES=

// 獨立 Prometheus /metrics server 的 listen address；預設 loopback。
# 本地 Docker Prometheus 抓取可設 0.0.0.0:9091；明確設空字串可停用。
# 勿對公網暴露。
METRICS_ADDR=127.0.0.1:9091

# 每個 client IP 的 rate limiting；設定 REDIS_HOST 時使用 Redis，否則使用 process 內 token bucket。
RATE_LIMIT_ENABLED=false
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40
# true 時限流後端故障拒絕請求（503）；false 為 fail-open（預設）。
RATE_LIMIT_FAIL_CLOSED=false

# production 預設 false；非 production 預設 true。僅內網需要時才在 production 開啟。
SWAGGER_ENABLED=

KEYCLOAK_BASE_URL=http://127.0.0.1:8080/realms/nexus-pro
KEYCLOAK_CLIENT_ID=nexus-pro-connect-api
KEYCLOAK_PROVISION_USERS=false
KEYCLOAK_ADMIN_CLIENT_ID=
KEYCLOAK_ADMIN_CLIENT_SECRET=
KEYCLOAK_SEND_INVITE_EMAIL=false
KEYCLOAK_INVITE_CLIENT_ID=nexus-pro-connect-api
KEYCLOAK_INVITE_REDIRECT_URL=

OPENFGA_BASE_URL=http://127.0.0.1:24081
OPENFGA_STORE_ID=
OPENFGA_MODEL_ID=
OPENFGA_SCOPE_CHECK_ENABLED=false

TEMPORAL_BASE_URL=127.0.0.1:27233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=nexus-workflows

NATS_ENABLED=false
NATS_BASE_URL=nats://127.0.0.1:24222
NATS_STREAM=NEXUS_EVENTS
NATS_CONSUMER_PREFIX=nexus

# Agent Chat / LiteLLM。設定 LiteLLM API key 後，預設啟用真實 ADK runtime。
# 未設定 LiteLLM API key 時會保持 chat disabled，不會拖垮其他 API 啟動。
LITELLM_BASE_URL=http://127.0.0.1:4000
LITELLM_API_KEY=
LITELLM_MASTER_KEY=
# 默認 Agent 模型由 LiteLLM config 的 nexus-agent-fallback alias 承載。
LITELLM_UPSTREAM_MODEL=openai/gpt-4.1-mini
# 知識庫固定調用公共 alias；上游模型只在 LiteLLM 配置中替換。
LITELLM_EMBEDDING_MODEL=nexus-pro-embedding
LITELLM_EMBEDDING_UPSTREAM_MODEL=openai/text-embedding-3-small

# Shared key for Agent model, MCP/external-tool, and other persisted secrets. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# 物件儲存：SFTPGo HTTP/HTTPS REST。production 請改 https://。
OBJECT_STORE_PROVIDER=sftpgo
OBJECT_STORE_CREATE_BUCKET=true
SFTPGO_BASE_URL=http://127.0.0.1:28080
SFTPGO_ROOT_BUCKET=nexus-bucket
SFTPGO_USERNAME=nexus-service
SFTPGO_PASSWORD=nexus-service

EHRMS_BASE_URL=
EHRMS_API_KEY=
EHRMS_SYNC_ENABLED=false
EHRMS_SYNC_INTERVAL=24h
EHRMS_SYNC_MODE=upsert
EHRMS_SYNC_TENANT_ID=
EHRMS_SYNC_ACCOUNT_ID=
EHRMS_SYNC_RUN_ON_START=false

EHRMS_ATTENDANCE_SYNC_ENABLED=false
EHRMS_ATTENDANCE_SYNC_INTERVAL=720h
EHRMS_ATTENDANCE_SYNC_MODE=upsert
EHRMS_ATTENDANCE_SYNC_TENANT_ID=
EHRMS_ATTENDANCE_SYNC_ACCOUNT_ID=
EHRMS_ATTENDANCE_SYNC_RUN_ON_START=false
EHRMS_ATTENDANCE_SYNC_SINCE=

OTEL_ENABLED=true
OTEL_SERVICE_NAME=nexus-pro-be
OTEL_BASE_URL=http://127.0.0.1:24317
OTEL_EXPORTER_OTLP_INSECURE=true
