APP_ENV=development
HTTP_ADDR=:8080
SEED_DEMO=true
LOG_LEVEL=info

DATABASE_URL=postgres://nexus:nexus@localhost:5432/nexus_pro_be?sslmode=disable

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

KEYCLOAK_ISSUER_URL=http://localhost:18080/realms/nexus-pro
KEYCLOAK_CLIENT_ID=nexus-pro-connect-api
ALLOW_DEMO_CONTEXT=false
ALLOW_HEADER_CONTEXT=false
ALLOW_UNSIGNED_JWT=false
AUTH_TOKEN_ISSUER=nexus-pro-be
AUTH_TOKEN_AUDIENCE=nexus-pro-be-api
AUTH_SESSION_SIGNING_KEY=
AUTH_STATE_SIGNING_KEY=

GOOGLE_OIDC_ISSUER_URL=https://accounts.google.com
GOOGLE_OIDC_CLIENT_ID=
GOOGLE_OIDC_CLIENT_SECRET=
GOOGLE_OIDC_REDIRECT_URL=http://localhost:8080/v1/auth/oidc/google/callback

MICROSOFT_OIDC_ISSUER_URL=https://login.microsoftonline.com/common/v2.0
MICROSOFT_OIDC_CLIENT_ID=
MICROSOFT_OIDC_CLIENT_SECRET=
MICROSOFT_OIDC_REDIRECT_URL=http://localhost:8080/v1/auth/oidc/microsoft/callback

OPENFGA_API_URL=http://localhost:8081
OPENFGA_STORE_ID=
OPENFGA_MODEL_ID=

OBJECT_STORE_PROVIDER=local
OBJECT_STORE_DIR=./var/objects
OBJECT_STORE_ENDPOINT=http://localhost:9000
OBJECT_STORE_BUCKET=nexus-hr-imports
OBJECT_STORE_REGION=us-east-1
OBJECT_STORE_ACCESS_KEY_ID=minioadmin
OBJECT_STORE_SECRET_ACCESS_KEY=minioadmin
OBJECT_STORE_USE_SSL=false
OBJECT_STORE_CREATE_BUCKET=false

OTEL_ENABLED=false
OTEL_SERVICE_NAME=nexus-pro-be
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true
