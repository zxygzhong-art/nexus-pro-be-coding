# nexus-pro-be 环境变量示例 —— 复制为 .env 并按需修改
# HTTP 服务监听地址
API_ADDR=:8088

# PostgreSQL 连接串。应用应以无 BYPASSRLS 的 app_user 连接，依赖 RLS 做租户隔离。
DB_DSN=postgres://app_user:app_pass@localhost:5432/nexus?sslmode=disable

# 迁移使用的 owner 连接（拥有建表/启用 RLS 权限）。留空则回退到 DB_DSN。
MIGRATE_DSN=postgres://nexus_owner:owner_pass@localhost:5432/nexus?sslmode=disable

# Redis 权限快照缓存。留空 = 使用 NoopCache（不缓存）。
REDIS_URL=

# 鉴权后端：local（本地权限引擎，默认）| openfga（预留）
AUTHZ_BACKEND=local

# OpenFGA（AUTHZ_BACKEND=openfga 时使用，目前为桩）
OPENFGA_API_URL=
OPENFGA_STORE_ID=
OPENFGA_MODEL_ID=

# Keycloak / OIDC（KEYCLOAK_ENABLED=true 时校验 Bearer JWT，目前为桩）
KEYCLOAK_ENABLED=false
KEYCLOAK_ISSUER=
KEYCLOAK_JWKS_URL=

# 日志级别：debug | info | warn | error
LOG_LEVEL=info
