# 統一的本地基礎設施部署設定。
# 先修改本檔，再執行：
#   ./render-configs.sh
#   docker compose --env-file .env up -d
#
# 主機欄位命名說明：
#   *_INTERNAL_HOST：容器或其他服務連線時使用；服務部署到別台主機時，改成該主機 IP/DNS。
#   *_BIND_HOST：本機 Docker 發佈 port 綁定的網卡；本機使用建議 0.0.0.0，需外部訪問時改 0.0.0.0 或指定內網 IP。

# Global.
# Compose 專案名稱；會影響沒有顯式命名的資源。容器已在 compose.yaml 中顯式命名。
COMPOSE_PROJECT_NAME=nexus-pro-be-ops
# 預設啟用的 Compose profile；all 表示部署整套服務。
COMPOSE_PROFILES=all
# Docker network 名稱；跨服務容器互連會使用此 network。
OBSERVABILITY_NETWORK=observability

# PostgreSQL.
# PostgreSQL 映像版本；固定版本，不使用 latest。
POSTGRES_IMAGE=postgres:18.4
# PostgreSQL 服務內部連線主機；外部已部署時改成對方 IP/DNS。
POSTGRES_INTERNAL_HOST=postgres
# PostgreSQL 容器內部 port。
POSTGRES_INTERNAL_PORT=5432
# PostgreSQL 對宿主機發佈 port 時綁定的網卡地址。
POSTGRES_BIND_HOST=127.0.0.1
# PostgreSQL 對宿主機發佈的 port。
POSTGRES_HOST_PORT=25432
# PostgreSQL superuser / 初始化使用者名稱。
POSTGRES_USER=nexuse-pro
# PostgreSQL 使用者密碼；正式環境必須更換。
POSTGRES_PASSWORD=nexus-pro-password
# PostgreSQL 預設資料庫名稱。
POSTGRES_DB=nexus_pro
# PostgreSQL healthcheck 執行間隔。
POSTGRES_HEALTHCHECK_INTERVAL=5s
# PostgreSQL healthcheck 單次逾時。
POSTGRES_HEALTHCHECK_TIMEOUT=5s
# PostgreSQL healthcheck 重試次數。
POSTGRES_HEALTHCHECK_RETRIES=30

# Redis.
# Redis 映像版本；固定版本，不使用 latest。
REDIS_IMAGE=redis:8.8.0
# Redis 容器內部 port。
REDIS_INTERNAL_PORT=6379
# Redis 對宿主機發佈 port 時綁定的網卡地址。
REDIS_BIND_HOST=127.0.0.1
# Redis 對宿主機發佈的 port。
REDIS_HOST_PORT=26379
# 後端從宿主機連到 Redis 的地址。
REDIS_ADDR=127.0.0.1:26379
# Redis 密碼；正式環境必須更換。
REDIS_PASSWORD=
# 後端使用的 Redis DB index。
REDIS_DB=0
# Redis 是否啟用 AOF 持久化。
REDIS_APPENDONLY=yes
# Redis healthcheck 執行間隔。
REDIS_HEALTHCHECK_INTERVAL=5s
# Redis healthcheck 單次逾時。
REDIS_HEALTHCHECK_TIMEOUT=5s
# Redis healthcheck 重試次數。
REDIS_HEALTHCHECK_RETRIES=30

# Keycloak.
# Keycloak 映像版本；固定版本，不使用 latest。
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.6.4
# Keycloak 服務內部連線主機；其他服務找 Keycloak 時使用。
KEYCLOAK_INTERNAL_HOST=keycloak
# Keycloak HTTP 容器內部 port。
KEYCLOAK_HTTP_INTERNAL_PORT=8080
# Keycloak HTTP 對宿主機發佈 port 時綁定的網卡地址。
KEYCLOAK_HTTP_BIND_HOST=127.0.0.1
# Keycloak HTTP 對宿主機發佈的 port。
KEYCLOAK_HTTP_HOST_PORT=8080
# Keycloak 管理/metrics 容器內部 port。
KEYCLOAK_MANAGEMENT_INTERNAL_PORT=9000
# Keycloak 管理/metrics 對宿主機發佈 port 時綁定的網卡地址。
KEYCLOAK_MANAGEMENT_BIND_HOST=127.0.0.1
# Keycloak 管理/metrics 對宿主機發佈的 port。
KEYCLOAK_MANAGEMENT_HOST_PORT=24990
# Keycloak 啟動命令；本地使用 start-dev，正式環境應改生產模式。
KEYCLOAK_COMMAND=start-dev
# Keycloak bootstrap admin 帳號。
KEYCLOAK_ADMIN_USER=admin
# Keycloak bootstrap admin 密碼；正式環境必須更換。
KEYCLOAK_ADMIN_PASSWORD=admin
# Keycloak 使用的 PostgreSQL database 名稱。
KEYCLOAK_DB_NAME=keycloak
# 是否啟用 Keycloak health endpoint。
KEYCLOAK_HEALTH_ENABLED=true
# 是否啟用 Keycloak metrics endpoint。
KEYCLOAK_METRICS_ENABLED=true
# Keycloak feature 清單；目前用於啟用 opentelemetry。
KEYCLOAK_FEATURES=opentelemetry
# 是否啟用 Keycloak tracing。
KEYCLOAK_TRACING_ENABLED=true
# Keycloak tracing protocol。
KEYCLOAK_TRACING_PROTOCOL=grpc
# Keycloak 上報 trace 時的 service.name。
KEYCLOAK_TRACING_SERVICE_NAME=keycloak
# Keycloak trace 採樣比例。
KEYCLOAK_TRACING_SAMPLER_RATIO=1.0
# Keycloak telemetry service name。
KEYCLOAK_TELEMETRY_SERVICE_NAME=keycloak

# OpenFGA.
# OpenFGA 映像版本；固定版本，不使用 latest。
OPENFGA_IMAGE=openfga/openfga:v1.18.1
# OpenFGA 服務內部連線主機。
OPENFGA_INTERNAL_HOST=openfga
# OpenFGA HTTP API 容器內部 port。
OPENFGA_HTTP_INTERNAL_PORT=8080
# OpenFGA HTTP API 對宿主機發佈 port 時綁定的網卡地址。
OPENFGA_HTTP_BIND_HOST=127.0.0.1
# OpenFGA HTTP API 對宿主機發佈的 port。
OPENFGA_HTTP_HOST_PORT=24081
# OpenFGA gRPC API 容器內部 port。
OPENFGA_GRPC_INTERNAL_PORT=8081
# OpenFGA gRPC API 對宿主機發佈 port 時綁定的網卡地址。
OPENFGA_GRPC_BIND_HOST=127.0.0.1
# OpenFGA gRPC API 對宿主機發佈的 port。
OPENFGA_GRPC_HOST_PORT=24082
# OpenFGA Playground 容器內部 port。    
OPENFGA_PLAYGROUND_INTERNAL_PORT=3000
# OpenFGA Playground 對宿主機發佈 port 時綁定的網卡地址。
OPENFGA_PLAYGROUND_BIND_HOST=127.0.0.1
# OpenFGA Playground 對宿主機發佈的 port。
OPENFGA_PLAYGROUND_HOST_PORT=24001
# OpenFGA metrics 容器內部 port。
OPENFGA_METRICS_INTERNAL_PORT=2112
# OpenFGA metrics 對宿主機發佈 port 時綁定的網卡地址。
OPENFGA_METRICS_BIND_HOST=127.0.0.1
# OpenFGA metrics 對宿主機發佈的 port。
OPENFGA_METRICS_HOST_PORT=24112
# OpenFGA 使用的 PostgreSQL database 名稱。
OPENFGA_DB_NAME=openfga
# 是否啟用 OpenFGA Playground。
OPENFGA_PLAYGROUND_ENABLED=true
# 是否啟用 OpenFGA Prometheus metrics。
OPENFGA_METRICS_ENABLED=true
# 是否啟用 OpenFGA tracing。
OPENFGA_TRACE_ENABLED=true
# OpenFGA 上報 OTLP trace 時是否使用 TLS。
OPENFGA_TRACE_OTLP_TLS_ENABLED=false
# OpenFGA trace 採樣比例。
OPENFGA_TRACE_SAMPLE_RATIO=1.0
# OpenFGA log 格式。
OPENFGA_LOG_FORMAT=json


# MinIO.
# MinIO server 映像版本；固定版本，不使用 latest。
MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
# MinIO client 映像版本；用於初始化 bucket。
MINIO_CLIENT_IMAGE=minio/mc:RELEASE.2025-08-13T08-35-41Z
# MinIO S3 API 服務內部連線主機。
MINIO_INTERNAL_HOST=minio
# MinIO S3 API 容器內部 port。
MINIO_API_INTERNAL_PORT=9000
# MinIO S3 API 對宿主機發佈 port 時綁定的網卡地址。
MINIO_API_BIND_HOST=127.0.0.1
# MinIO S3 API 對宿主機發佈的 port。
MINIO_API_HOST_PORT=24900
# MinIO Console 容器內部 port。
MINIO_CONSOLE_INTERNAL_PORT=9001
# MinIO Console 對宿主機發佈 port 時綁定的網卡地址。
MINIO_CONSOLE_BIND_HOST=127.0.0.1
# MinIO Console 對宿主機發佈的 port。
MINIO_CONSOLE_HOST_PORT=24901
# MinIO root 帳號；正式環境必須更換。
MINIO_ROOT_USER=minioadmin
# MinIO root 密碼；正式環境必須更換。
MINIO_ROOT_PASSWORD=minioadmin
# MinIO Prometheus metrics 授權模式；public 便於本地 Prometheus 抓取。
MINIO_PROMETHEUS_AUTH_TYPE=public

# Backend object store.
# 後端物件儲存 provider；預設使用 MinIO。
OBJECT_STORE_PROVIDER=minio
# 後端從宿主機連到物件儲存的 endpoint；若 MinIO 在其他主機，改成該主機 URL。
OBJECT_STORE_ENDPOINT=http://127.0.0.1:24900
# 後端業務文件 bucket 名稱。
OBJECT_STORE_BUCKET=nexus-hr-imports
# 物件儲存 region；MinIO 本地預設 us-east-1。
OBJECT_STORE_REGION=us-east-1
# 後端連物件儲存的 access key；本地預設與 MinIO root user 相同。
OBJECT_STORE_ACCESS_KEY_ID=minioadmin
# 後端連物件儲存的 secret key；正式環境必須更換。
OBJECT_STORE_SECRET_ACCESS_KEY=minioadmin
# 後端連物件儲存時是否使用 SSL；endpoint 有 http/https scheme 時會優先依 scheme 判斷。
OBJECT_STORE_USE_SSL=false
# 後端啟動時是否自動建立 bucket。
OBJECT_STORE_CREATE_BUCKET=true



# OpenTelemetry Collector.
# OpenTelemetry Collector 映像版本；固定版本，不使用 latest。
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.155.0
# OpenTelemetry Collector 服務內部連線主機。
OTEL_COLLECTOR_INTERNAL_HOST=otel-collector
# OTLP gRPC receiver 容器內部 port。
OTEL_GRPC_INTERNAL_PORT=4317
# OTLP gRPC 對宿主機發佈 port 時綁定的網卡地址。
OTEL_GRPC_BIND_HOST=127.0.0.1
# OTLP gRPC 對宿主機發佈的 port。
OTEL_GRPC_HOST_PORT=24317
# OTLP HTTP receiver 容器內部 port。
OTEL_HTTP_INTERNAL_PORT=4318
# OTLP HTTP 對宿主機發佈 port 時綁定的網卡地址。
OTEL_HTTP_BIND_HOST=127.0.0.1
# OTLP HTTP 對宿主機發佈的 port。
OTEL_HTTP_HOST_PORT=24318
# Collector 給 Prometheus scrape 的 exporter 容器內部 port。
OTEL_PROMETHEUS_EXPORT_INTERNAL_PORT=8889
# Collector Prometheus exporter 對宿主機發佈 port 時綁定的網卡地址。
OTEL_PROMETHEUS_EXPORT_BIND_HOST=127.0.0.1
# Collector Prometheus exporter 對宿主機發佈的 port。
OTEL_PROMETHEUS_EXPORT_HOST_PORT=24889
# 宿主機 Go 後端上報 OTLP trace 的 gRPC endpoint；目前後端使用 otlptracegrpc。
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:24317
# 其他 SDK 如需使用 OTLP HTTP，可改用 http://127.0.0.1:24318 並搭配自身 protocol 設定。
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# 後端服務的 OpenTelemetry service.name。
OTEL_SERVICE_NAME=nexus-pro-be
# OpenTelemetry resource attributes。
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local
# Collector 從宿主機抓取後端 Prometheus /metrics 的目標。
NEXUS_API_METRICS_TARGET=host.docker.internal:9091
# Collector 容器內讀取後端 JSON 日誌的 include pattern；對應 compose 中的 ../logs 掛載。
NEXUS_API_LOG_INCLUDE=/var/log/nexus-pro-be/*.log
# filelog 初次讀取位置；local demo 可改 beginning 重新匯入既有日誌。
NEXUS_API_LOG_START_AT=end
# Collector 補到 metrics/logs/traces resource 上的 deployment.environment。
NEXUS_API_DEPLOYMENT_ENVIRONMENT=local
# OTLP HTTP CORS 允許來源 1。
OTEL_CORS_ALLOWED_ORIGIN_1=http://localhost:*
# OTLP HTTP CORS 允許來源 2。
OTEL_CORS_ALLOWED_ORIGIN_2=http://0.0.0.0:*
# Collector memory limiter 上限 MiB。
OTEL_MEMORY_LIMIT_MIB=512
# Collector memory limiter spike 上限 MiB。
OTEL_MEMORY_SPIKE_LIMIT_MIB=128
# Collector batch processor timeout。
OTEL_BATCH_TIMEOUT=5s
# Collector batch processor send batch size。
OTEL_BATCH_SEND_SIZE=1024

# Prometheus.
# Prometheus 映像版本；固定版本，不使用 latest。
PROMETHEUS_IMAGE=prom/prometheus:v3.13.0
# Prometheus 服務內部連線主機。
PROMETHEUS_INTERNAL_HOST=prometheus
# Prometheus 容器內部 port。
PROMETHEUS_INTERNAL_PORT=9090
# Prometheus 對宿主機發佈 port 時綁定的網卡地址。
PROMETHEUS_BIND_HOST=127.0.0.1
# Prometheus 對宿主機發佈的 port。
PROMETHEUS_HOST_PORT=24090
# Prometheus scrape interval。
PROMETHEUS_SCRAPE_INTERVAL=15s
# Prometheus rule evaluation interval。
PROMETHEUS_EVALUATION_INTERVAL=15s
# Prometheus 本地 TSDB 保留時間。
PROMETHEUS_RETENTION=15d

# Loki.
# Loki 映像版本；固定版本，不使用 latest。
LOKI_IMAGE=grafana/loki:3.7.3
# Loki 服務內部連線主機。
LOKI_INTERNAL_HOST=loki
# Loki HTTP API 容器內部 port。
LOKI_HTTP_INTERNAL_PORT=3100
# Loki HTTP API 對宿主機發佈 port 時綁定的網卡地址。
LOKI_HTTP_BIND_HOST=127.0.0.1
# Loki HTTP API 對宿主機發佈的 port。
LOKI_HTTP_HOST_PORT=24100
# Loki gRPC 容器內部 port。
LOKI_GRPC_INTERNAL_PORT=9095
# Loki 使用的 MinIO bucket 名稱。
LOKI_BUCKET=nexus-pro-loki
# Loki log retention 時間。
LOKI_RETENTION=168h
# Loki schema 生效日期。
LOKI_SCHEMA_FROM=2024-04-01
# Loki index prefix。
LOKI_INDEX_PREFIX=loki_index_
# Loki 連 MinIO/S3 時是否使用 insecure HTTP。
LOKI_S3_INSECURE=true
# Loki 連 MinIO/S3 時是否強制 path-style。
LOKI_S3_FORCE_PATH_STYLE=true

# Tempo.
# Tempo 映像版本；固定版本，不使用 latest。
TEMPO_IMAGE=grafana/tempo:3.0.2
# Tempo 服務內部連線主機。
TEMPO_INTERNAL_HOST=tempo
# Tempo HTTP API 容器內部 port。
TEMPO_HTTP_INTERNAL_PORT=3200
# Tempo HTTP API 對宿主機發佈 port 時綁定的網卡地址。
TEMPO_HTTP_BIND_HOST=127.0.0.1
# Tempo HTTP API 對宿主機發佈的 port。
TEMPO_HTTP_HOST_PORT=24200
# Tempo 使用的 MinIO bucket 名稱。
TEMPO_BUCKET=nexus-pro-tempo
# Tempo 連 MinIO/S3 時是否使用 insecure HTTP。
TEMPO_S3_INSECURE=true

# Grafana.
# Grafana 映像版本；固定版本，不使用 latest。
GRAFANA_IMAGE=grafana/grafana:13.1.0
# Grafana 容器內部 port。
GRAFANA_INTERNAL_PORT=3000
# Grafana 對宿主機發佈 port 時綁定的網卡地址。
GRAFANA_BIND_HOST=127.0.0.1
# Grafana 對宿主機發佈的 port。
GRAFANA_HOST_PORT=24000
# Grafana admin 帳號。
GRAFANA_ADMIN_USER=admin
# Grafana admin 密碼；正式環境必須更換。
GRAFANA_ADMIN_PASSWORD=admin
# 是否允許 Grafana 使用者自行註冊。
GRAFANA_ALLOW_SIGN_UP=false
# 是否啟用 Grafana anonymous auth。
GRAFANA_ANONYMOUS_ENABLED=false




# Temporal.
# Temporal auto-setup 映像版本；固定版本，不使用 latest。
TEMPORAL_IMAGE=temporalio/auto-setup:1.29.7
# Temporal UI 映像版本；固定版本，不使用 latest。
TEMPORAL_UI_IMAGE=temporalio/ui:2.51.1
# Temporal admin-tools 映像版本；固定版本，不使用 latest。
TEMPORAL_ADMIN_TOOLS_IMAGE=temporalio/admin-tools:1.29.7-tctl-1.18.4-cli-1.7.2
# Temporal frontend 服務內部連線主機。
TEMPORAL_INTERNAL_HOST=temporal
# Temporal frontend gRPC 容器內部 port。
TEMPORAL_GRPC_INTERNAL_PORT=7233
# Temporal frontend gRPC 對宿主機發佈 port 時綁定的網卡地址。
TEMPORAL_GRPC_BIND_HOST=127.0.0.1
# Temporal frontend gRPC 對宿主機發佈的 port。
TEMPORAL_GRPC_HOST_PORT=27233
# Temporal UI 容器內部 port。
TEMPORAL_UI_INTERNAL_PORT=8080
# Temporal UI 對宿主機發佈 port 時綁定的網卡地址。
TEMPORAL_UI_BIND_HOST=127.0.0.1
# Temporal UI 對宿主機發佈的 port。
TEMPORAL_UI_HOST_PORT=24088
# Temporal 使用的 PostgreSQL database 名稱。
TEMPORAL_DB_NAME=temporal
# Temporal visibility 使用的 PostgreSQL database 名稱。
TEMPORAL_VISIBILITY_DB_NAME=temporal_visibility
# Temporal 預設 namespace。
TEMPORAL_DEFAULT_NAMESPACE=default
# Temporal 連 PostgreSQL 時使用的 database driver 類型。
TEMPORAL_DB=postgres12
# Temporal dynamic config 檔案在容器內的位置。
TEMPORAL_DYNAMIC_CONFIG_FILE_PATH=config/dynamicconfig/development-sql.yaml
# Temporal dynamic config：讀取 search attributes 時是否強制刷新 cache。
TEMPORAL_FORCE_SEARCH_ATTRIBUTES_CACHE_REFRESH=true
# Temporal UI 允許的 CORS origins。
TEMPORAL_CORS_ORIGINS=http://localhost:3002,http://localhost:24088

# NATS JetStream.
# NATS 映像版本；固定版本，不使用 latest。
NATS_IMAGE=nats:2.14.3
# NATS client 容器內部 port。
NATS_CLIENT_INTERNAL_PORT=4222
# NATS client 對宿主機發佈 port 時綁定的網卡地址。
NATS_CLIENT_BIND_HOST=127.0.0.1
# NATS client 對宿主機發佈的 port。
NATS_CLIENT_HOST_PORT=24222
# NATS monitoring HTTP 容器內部 port。
NATS_MONITOR_INTERNAL_PORT=8222
# NATS monitoring HTTP 對宿主機發佈 port 時綁定的網卡地址。
NATS_MONITOR_BIND_HOST=127.0.0.1
# NATS monitoring HTTP 對宿主機發佈的 port。
NATS_MONITOR_HOST_PORT=28222
# NATS server name。
NATS_SERVER_NAME=nexus-pro-nats
# NATS JetStream 資料目錄。
NATS_JETSTREAM_STORE_DIR=/data/jetstream
# 應用程式從宿主機連到 NATS 的 URL。
NATS_URL=nats://127.0.0.1:24222
